rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based helper: Is user a member of the household?
    function isHouseholdMember(householdId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAll(['householdIds']) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdIds.hasAny([householdId])) ||
        (exists(/databases/$(database)/documents/households/$(householdId)) &&
         get(/databases/$(database)/documents/households/$(householdId)).data.memberIds.hasAny([request.auth.uid]))
      );
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'uid', 'createdAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.uid == request.auth.uid;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'type', 'category', 'description', 'date', 'userId', 'userName', 'createdAt', 'memberIds']) &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.category is string && data.category.size() <= 50 &&
             data.date is string && data.date.size() <= 20 &&
             data.userId == request.auth.uid &&
             data.memberIds is list;
    }

    function isValidHousehold(data) {
      return data.keys().hasAll(['name', 'createdBy', 'memberIds', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.memberIds is list && data.memberIds.size() <= 10;
    }

    function isValidInvitation(data) {
      return data.keys().hasAll(['householdId', 'householdName', 'invitedByEmail', 'invitedByName', 'invitedByUserId', 'invitedUserId', 'status', 'createdAt', 'memberIds', 'invitedUserEmail']) &&
             data.status in ['pending', 'accepted', 'declined'] &&
             data.invitedByUserId == request.auth.uid;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['householdId', 'householdIds', 'displayName', 'photoURL'])
      );
    }

    match /users/{userId}/transactions/{id} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidTransaction(incoming());
      allow update: if isOwner(userId) && isValidTransaction(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'category', 'description', 'date', 'notes', 'type', 'scope'])
      );
      allow delete: if isOwner(userId);
    }
    
    match /users/{userId}/goals/{id} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/recurring/{id} {
      allow read, write: if isOwner(userId);
    }

    // --- Households (Shared Groups) ---
    match /households/{householdId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.memberIds.hasAny([request.auth.uid]) || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && isValidHousehold(incoming());
      allow update: if isSignedIn() && (
                      ( (resource.data.memberIds.hasAny([request.auth.uid]) || resource.data.createdBy == request.auth.uid) && 
                        incoming().memberIds.size() <= 10 && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['memberIds', 'name']) ) ||
                      // Action: Join via invitation
                      (
                        exists(/databases/$(database)/documents/invitations/$(request.auth.uid + "_" + householdId)) &&
                        (get(/databases/$(database)/documents/invitations/$(request.auth.uid + "_" + householdId)).data.status == 'pending' ||
                         getAfter(/databases/$(database)/documents/invitations/$(request.auth.uid + "_" + householdId)).data.status == 'accepted') &&
                        incoming().memberIds.hasAny([request.auth.uid]) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['memberIds'])
                      )
                    );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /transactions/{transactionId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId) && isValidTransaction(incoming());
        allow update: if isHouseholdMember(householdId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'category', 'description', 'date', 'notes', 'splits', 'type', 'scope', 'memberIds'])
        );
        allow delete: if isHouseholdMember(householdId);
      }
      match /goals/{goalId} {
        allow read, write: if isHouseholdMember(householdId);
      }
      match /recurring/{recurringId} {
        allow read, write: if isHouseholdMember(householdId);
      }
    }

    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (
        resource.data.invitedUserId == request.auth.uid ||
        resource.data.invitedByUserId == request.auth.uid ||
        resource.data.memberIds.hasAny([request.auth.uid])
      );
      allow update: if isSignedIn() && (
        ( resource.data.invitedUserId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']) ) ||
        ( resource.data.invitedByUserId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']) )
      );
      allow delete: if isSignedIn() && (resource.data.invitedUserId == request.auth.uid || resource.data.invitedByUserId == request.auth.uid);
      allow create: if isSignedIn() && isHouseholdMember(incoming().householdId) && isValidInvitation(incoming());
    }
  }
}
