rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based helper: Is user a member is the household?
    function isHouseholdMember(householdId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/households/$(householdId)).data.memberIds.hasAny([request.auth.uid]);
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (existing().householdId != null && isHouseholdMember(existing().householdId));
    }

    match /users/{userId}/transactions/{id} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/goals/{id} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/recurring/{id} {
      allow read, write: if isOwner(userId);
    }

    // --- Households (Shared Groups) ---
    match /households/{householdId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.memberIds.hasAny([request.auth.uid]);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
                      resource.data.memberIds.hasAny([request.auth.uid]) ||
                      resource.data.createdBy == request.auth.uid ||
                      (
                        // Allow joining if there's a deterministic pending invitation
                        exists(/databases/$(database)/documents/invitations/$(request.auth.uid + "_" + householdId)) &&
                        get(/databases/$(database)/documents/invitations/$(request.auth.uid + "_" + householdId)).data.status == 'pending' &&
                        request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
                        request.resource.data.memberIds.hasAny([request.auth.uid])
                      )
                    );
      allow delete: if isSignedIn() && resource.data.memberIds.hasAny([request.auth.uid]);

      match /transactions/{transactionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
      match /goals/{goalId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isHouseholdMember(householdId);
      }
      match /recurring/{recurringId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isHouseholdMember(householdId);
      }
    }

    match /invitations/{invitationId} {
      allow read: if isSignedIn() && resource.data.invitedUserId == request.auth.uid;
      allow create: if isSignedIn() && isHouseholdMember(incoming().householdId);
      allow update, delete: if isSignedIn() && resource.data.invitedUserId == request.auth.uid;
    }
  }
}
